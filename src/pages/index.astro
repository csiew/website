---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE, absoluteUrl, formatDate } from "../lib/site";

const projects = (await getCollection("projects"))
  .sort((a, b) => b.data.duration.start.localeCompare(a.data.duration.start))
  .slice(0, 4);

const posts = (await getCollection("posts"))
  .filter((post) => !post.data.private)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

function durationLabel(project: typeof projects[number]) {
  const { start, end } = project.data.duration;
  return start === end ? start : `${start} - ${end}`;
}

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: SITE.name,
    url: absoluteUrl("/"),
    image: absoluteUrl("/profile.jpg"),
    jobTitle: "Software Engineer",
    address: {
      "@type": "PostalAddress",
      addressLocality: "Melbourne",
      addressCountry: "AU"
    },
    sameAs: [
      "https://linkedin.com/in/clarencesiew",
      "https://github.com/csiew",
      "https://mastodon.online/@csiew",
      "https://bsky.app/profile/csiew.bsky.social",
      "https://threads.net/@clarence_siew",
      "https://instagram.com/clarence_siew"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE.name,
    url: absoluteUrl("/")
  }
];
---

<BaseLayout
  title={SITE.name}
  description={SITE.description}
  pathname="/"
  image="/profile.jpg"
  imageAlt={SITE.name}
  structuredData={structuredData}
>
  <div class="home">
    <section class="home-hero" aria-labelledby="home-title">
      <h1 id="home-title">Clarence Siew</h1>
      <p class="lede">Software engineer in Melbourne building web apps, browser tools, and services.</p>
      <p>Originally from Penang, Malaysia. Started with Windows batch scripts at 10; still happiest turning small technical obsessions into useful software.</p>
    </section>

    <section class="home-section" aria-labelledby="selected-projects">
      <div class="section-heading">
        <h2 id="selected-projects">Selected projects</h2>
        <a href="/projects">All projects</a>
      </div>
      <div class="index-list">
        {projects.map((project) => (
          <article>
            <a href={`/projects/${project.data.slug}`}>{project.data.title}</a>
            <p>{project.data.subtitle}</p>
            <span>{durationLabel(project)}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="home-section" aria-labelledby="recent-writing">
      <div class="section-heading">
        <h2 id="recent-writing">Recent writing</h2>
        <a href="/posts">All writing</a>
      </div>
      <div class="index-list">
        {posts.map((post) => (
          <article>
            <a href={`/posts/${post.data.slug}`}>{post.data.title}</a>
            <p>{post.data.subtitle}</p>
            <span>{formatDate(post.data.publishedAt)}</span>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
