---
import BaseLayout from "../layouts/BaseLayout.astro";
import Feed from "../components/Feed";
import { SITE } from "../lib/site";
---

<BaseLayout
  title={`Feed | ${SITE.name}`}
  description="Clarence's Mastodon feed"
  pathname="/feed"
>
  <h2>Feed</h2>
  <p class="subheading">Short notes and links from Mastodon.</p>
  <Feed client:load />
</BaseLayout>
